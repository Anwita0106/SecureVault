# SecureVault Environment Configuration
# Copy this file to .env and update values

# Application
APP_NAME=SecureVault
DEBUG=false

# SECURITY - CHANGE THESE IN PRODUCTION!
SECRET_KEY=change-this-secret-key-to-random-32-chars-min
JWT_SECRET_KEY=change-this-jwt-secret-key-random-32-chars
ENCRYPTION_KEY=change-this-encryption-key-32-chars-min

# Database
DATABASE_URL=postgresql+asyncpg://securevault:securevault_pass@db:5432/securevault

# Redis
REDIS_URL=redis://redis:6379/0

# Storage: "local" or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage/files
MAX_FILE_SIZE_MB=100

# AWS S3 (if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=securevault-files

# ClamAV Malware Scanning
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_ENABLED=false

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin user (created on first startup)
ADMIN_EMAIL=admin@securevault.local
ADMIN_PASSWORD=Admin@SecureVault2024!

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]

# Email (optional, for password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
